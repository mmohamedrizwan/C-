## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build folders
bin/
obj/
out/
Debug/
Release/

# Rider
.idea/

# VS Code
.vscode/

# Visual Studio files
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet Packages
*.nupkg
# NuGet Package Restore
packages/
*.snupkg

# Logs
*.log

# Visual Studio Cache files
.vs/

# Autogenerated files
Generated/
GeneratedFiles/

# Publish output
publish/
appsettings.Development.json

# dotnet CLI
*.assets.json
project.lock.json
project.fragment.lock.json

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Files built by Visual Studio
*.dll
*.exe
*.pdb
*.cache
*.config
*.dbmdl

# Others
*.db
*.bak
*.model.json
*.tmp
*.temp

# Coverage / Analysis
TestResults/
coverage/
*.coverage
*.coveragexml

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper

# Azure local settings
local.settings.json

# SQL
*.mdf
*.ldf

# OS generated files
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Node (just in case)
node_modules/